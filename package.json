{
  "name": "@figma/my-make-file",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/src/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsup server/src/index.ts --format esm --platform node --target node20 --out-dir server/dist --clean",
    "postinstall": "npm run prisma:generate",
    "prisma:prepare": "npm run prisma:generate && npm run prisma:migrate:deploy",
    "prestart": "npm run prisma:prepare",
    "start": "node server/dist/index.js",
    "test": "vitest run",
    "prisma:generate": "prisma generate --schema server/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema server/prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema server/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema server/prisma/schema.prisma"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
